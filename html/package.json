{
  "name": "angular-aggrid-performance-debug",
  "version": "1.0.0",
  "description": "Angular 15 ag-grid performance debugging example",
  "scripts": {
    "generate-data": "node data-generator.js",
    "generate-small": "node data-generator.js --size=10MB",
    "generate-medium": "node data-generator.js --size=200MB",
    "generate-large": "node data-generator.js --size=500MB",
    "generate-huge": "node data-generator.js --size=1GB",
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode production"
  },
  "dependencies": {
    "@angular/animations": "^15.2.10",
    "@angular/common": "^15.2.10",
    "@angular/compiler": "^15.2.10",
    "@angular/core": "^15.2.10",
    "@angular/platform-browser": "^15.2.10",
    "@angular/platform-browser-dynamic": "^15.2.10",
    "ag-grid-angular": "^29.3.5",
    "ag-grid-community": "^29.3.5",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "^0.12.0"
  },
  "devDependencies": {
    "@angular/compiler-cli": "^15.2.10",
    "@types/node": "^20.11.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "~4.9.5",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}